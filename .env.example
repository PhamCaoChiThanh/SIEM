# SIEM Configuration Example
# Copy this to a file named .env and fill in your details

# --- Email Alerts (SMTP) ---
# The email address that will SEND the alerts
SMTP_USER=chithanhphamj@gmail.com

# For Gmail: Use an 'App Password', NOT your regular password.
# How to get it: Google Account > Security > 2-Step Verification > App Passwords
SMTP_PASS=iynzghznifmdesin

# The email address that will RECEIVE the alerts
EMAIL_TO=chithanhphamj@gmail.com

# SMTP Server Settings (Default is Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
